# Expo push notifications — run `eas init` and paste the project ID here
EXPO_PUBLIC_EAS_PROJECT_ID=

# Public legal documents linked during account creation
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_PRIVACY_URL=

# Crash reporting — create a "React Native" project in Sentry and paste its
# DSN here. Unset = Sentry never initializes (safe default for local dev).
EXPO_PUBLIC_SENTRY_DSN=
